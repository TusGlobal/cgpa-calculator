# ── Keywords reference ────────────────────────────────────────────────────────
DATA_ANALYTICS_KW = [
    "Python", "SQL", "R", "Machine Learning", "Data Wrangling", "Pandas", "NumPy",
    "Power BI", "Tableau", "Dashboards", "Statistics", "ETL", "Data Pipeline",
    "Data Visualisation", "Big Data", "Hadoop", "Spark", "Database", "Applied Mathematics",
    "Regression", "Classification", "Neural Networks", "Feature Engineering",
]
BUSINESS_ANALYTICS_KW = [
    "SQL", "Python", "Excel", "Power BI", "Tableau", "Dashboards", "SAP",
    "Business Strategy", "Data Integration", "Reporting", "KPI", "CRM", "ERP",
    "Market Analysis", "Financial Modelling", "Business Intelligence", "Forecasting",
    "Operations Research", "Supply Chain", "Data-driven Decision Making",
]
COGNATE_BACKLOGS = [
    "Accounting", "Applied Mathematics", "Database", "Python", "SQL", "Calculus",
    "Statistics", "Data Structures", "Business Analytics", "Operations Research",
]

# ── Helper: render verdict ────────────────────────────────────────────────────
def verdict(style, title, details, keywords=None):
    kw_html = ""
    if keywords:
        pills = "".join(f'<span class="pill">{k}</span>' for k in keywords)
        kw_html = f'<div class="kw-list"><strong>Relevant keywords to look for:</strong><br>{pills}</div>'
    st.markdown(f"""
<div class="card card-{style}">
  <div class="verdict">{title}</div>
  <div class="detail">{details}</div>
  {kw_html}
</div>
""", unsafe_allow_html=True)

def progress(step, total=6):
    pct = int((step / total) * 100)
    st.markdown(f"""
<div class="progress-bar-wrap">
  <div class="progress-bar-fill" style="width:{pct}%"></div>
</div>
""", unsafe_allow_html=True)

# ════════════════════════════════════════════════════════════════════════════
# STEP 1 — Course
# ════════════════════════════════════════════════════════════════════════════
st.markdown('<div class="step-label">Step 1 — Programme</div>', unsafe_allow_html=True)
course = st.selectbox(
    "Which MSc programme is the student applying for?",
    ["— Select —", "MSc Data Analytics", "MSc Business Analytics"],
)
if course == "— Select —":
    progress(0)
    st.stop()

progress(1)

# ════════════════════════════════════════════════════════════════════════════
# STEP 2 — UG Background
# ════════════════════════════════════════════════════════════════════════════
st.markdown('<div class="step-label">Step 2 — Undergraduate Background</div>', unsafe_allow_html=True)

if course == "MSc Data Analytics":
    allowed_degrees = ["— Select —", "B.Tech / B.E.", "Other (not eligible)"]
    degree_note = "MSc Data Analytics accepts B.Tech / B.E. graduates only."
else:
    allowed_degrees = ["— Select —", "B.Tech / B.E.", "BBA", "BCom", "Other (not eligible)"]
    degree_note = "MSc Business Analytics accepts B.Tech / B.E., BBA, and BCom graduates."

st.caption(degree_note)
ug_degree = st.selectbox("Undergraduate degree", allowed_degrees)

if ug_degree == "— Select —":
    progress(1)
    st.stop()

if ug_degree == "Other (not eligible)":
    progress(2)
    verdict(
        "red",
        "Not Eligible — Degree Not Accepted",
        f"The undergraduate degree does not meet the entry requirements for {course}. "
        f"{degree_note} Please advise the student to review the programme requirements.",
    )
    st.stop()

progress(2)

# ════════════════════════════════════════════════════════════════════════════
# STEP 3 — Marks / Percentage
# ════════════════════════════════════════════════════════════════════════════
st.markdown('<div class="step-label">Step 3 — Academic Score</div>', unsafe_allow_html=True)

pct_label = "Undergraduate percentage (%)"
marks = st.number_input(pct_label, min_value=0.0, max_value=100.0, step=0.1, format="%.1f", value=0.0)

if marks == 0.0:
    progress(2)
    st.stop()

progress(3)

is_btech = ug_degree == "B.Tech / B.E."
is_arts  = ug_degree in ("BBA", "BCom")

# Threshold logic
if is_btech:
    min_pct = 60.0
    threshold_label = "60% (equivalent to a 2:2 Honours degree)"
else:
    min_pct = 70.0
    threshold_label = "70%"

marks_pass = marks >= min_pct

# ════════════════════════════════════════════════════════════════════════════
# STEP 4 — Backlogs
# ════════════════════════════════════════════════════════════════════════════
st.markdown('<div class="step-label">Step 4 — Academic Backlogs</div>', unsafe_allow_html=True)
backlogs = st.number_input("Total number of backlogs (failed/re-sit subjects)", min_value=0, max_value=30, step=1, value=0)

st.markdown("---")

# ════════════════════════════════════════════════════════════════════════════
# DECISION TREE
# ════════════════════════════════════════════════════════════════════════════

kw_list = DATA_ANALYTICS_KW if course == "MSc Data Analytics" else BUSINESS_ANALYTICS_KW

# ── Case: Marks below threshold ─────────────────────────────────────────────
if not marks_pass:
    if is_btech:
        verdict(
            "amber",
            "Below 2:2 Honours — Your Discretion",
            f"The student has scored <strong>{marks:.1f}%</strong>, which is below the "
            f"standard entry requirement of {threshold_label} for {course}. "
            f"This falls below the equivalent of a 2:2 Honours degree. "
            f"<br><br>An offer letter <strong>may still be issued at your discretion</strong>, "
            f"particularly if the student has strong relevant work experience or cognate "
            f"subject background. Document your rationale before proceeding.",
            keywords=kw_list,
        )
    else:
        # BBA / BCom below 70%
        st.markdown('<div class="step-label">Step 5 — Work Experience Check</div>', unsafe_allow_html=True)
        work_exp = st.number_input("Years of relevant work experience", min_value=0, max_value=30, step=1, value=0)
        if work_exp > 0:
            cognate_work = st.radio(
                "Does the work experience appear cognate? "
                "(e.g. roles involving data, analytics, finance, business strategy, reporting)",
                ["— Select —", "Yes — cognate work experience", "No — unrelated field"],
            )
            if cognate_work == "— Select —":
                progress(4)
                st.stop()
            if cognate_work == "Yes — cognate work experience":
                verdict(
                    "amber",
                    "Borderline — Cognate Work Experience Present",
                    f"The student has scored <strong>{marks:.1f}%</strong> (below the {threshold_label} "
                    f"threshold for {ug_degree}) but has <strong>{work_exp} year(s)</strong> of cognate "
                    f"work experience. This <strong>does not automatically qualify</strong> them — "
                    f"the admissions team should review the full profile. "
                    f"If work experience is strong and clearly relevant, a conditional offer may be considered "
                    f"at your discretion. Document your reasoning.",
                    keywords=kw_list,
                )
            else:
                verdict(
                    "red",
                    "Not Eligible",
                    f"The student has scored <strong>{marks:.1f}%</strong> (below {threshold_label}) "
                    f"and does not have cognate work experience. "
                    f"The entry requirements for {course} are not met.",
                )
        else:
            verdict(
                "red",
                "Not Eligible",
                f"The student has scored <strong>{marks:.1f}%</strong>, which is below the "
                f"{threshold_label} requirement for {ug_degree} graduates applying to {course}, "
                f"and no work experience has been recorded. "
                f"Entry requirements are not met.",
            )
    st.stop()

# ── Marks pass — now assess backlogs ────────────────────────────────────────

if backlogs < 4:
    # Clean or minor backlogs
    progress(5)
    verdict(
        "green",
        "Conditional Offer Letter — Recommended",
        f"The student meets the academic entry requirements for <strong>{course}</strong>. "
        f"Score: <strong>{marks:.1f}%</strong> ({ug_degree}) with <strong>{backlogs} backlog(s)</strong> "
        f"(below the threshold of 4). "
        f"<br><br>A <strong>Conditional Offer Letter</strong> can be issued. "
        f"Conditions should include: final transcript showing no outstanding backlogs, "
        f"and official degree certificate upon graduation.",
        keywords=kw_list,
    )

else:
    # 4 or more backlogs
    progress(4)
    st.markdown('<div class="step-label">Step 5 — Backlog Subject Check</div>', unsafe_allow_html=True)
    st.caption(
        "With 4 or more backlogs we need to assess whether the failed subjects are cognate "
        "to the programme. Cognate subjects indicate the student attempted challenging, "
        "relevant material — not that they avoided it."
    )
    cognate_pill = "  ·  ".join(COGNATE_BACKLOGS)
    st.markdown(
        f'<div style="font-size:0.82rem;color:#555;margin-bottom:10px;">' +
        f'<strong>Cognate subjects include:</strong> {cognate_pill}</div>',
        unsafe_allow_html=True,
    )
    cognate_backlogs = st.radio(
        "Do the backlog subjects appear cognate to the programme?",
        ["— Select —",
         "Yes — backlogs are in subjects like Accounting / Applied Maths / Database / Python / SQL / Calculus",
         "No — backlogs are in unrelated subjects"],
    )

    if cognate_backlogs == "— Select —":
        progress(4)
        st.stop()

    if cognate_backlogs.startswith("No"):
        verdict(
            "red",
            "Not Eligible — High Backlogs, Non-Cognate",
            f"The student has <strong>{backlogs} backlogs</strong> in subjects unrelated to "
            f"the programme. This does not demonstrate the academic foundation required for "
            f"{course}. Entry requirements are not met.",
        )
        st.stop()

    # Cognate backlogs — check work experience
    progress(5)
    st.markdown('<div class="step-label">Step 6 — Work Experience</div>', unsafe_allow_html=True)
    work_exp = st.number_input("Years of relevant work experience", min_value=0, max_value=30, step=1, value=0)

    if work_exp == 0:
        verdict(
            "red",
            "Not Eligible — High Backlogs, No Work Experience",
            f"The student has <strong>{backlogs} cognate backlogs</strong> but no work experience "
            f"to offset the academic risk. Entry requirements for {course} are not met.",
        )
        st.stop()

    if work_exp < 3:
        verdict(
            "amber",
            "Borderline — Insufficient Work Experience",
            f"The student has <strong>{backlogs} cognate backlogs</strong> and "
            f"<strong>{work_exp} year(s)</strong> of work experience. "
            f"A minimum of 3 years is expected to offset 4+ backlogs. "
            f"This case requires senior admissions team review before any offer is made.",
            keywords=kw_list,
        )
        st.stop()

    # ≥3 years work experience — check resume keywords
    progress(6)
    st.markdown('<div class="step-label">Step 7 — Resume Keyword Check</div>', unsafe_allow_html=True)
    resume_kw_options = [
        "Data Integration", "SQL", "Python", "Dashboards", "Business Strategy",
        "SAP", "Excel", "Power BI", "Tableau", "Reporting", "ETL", "Machine Learning",
        "CRM / ERP", "KPI Analysis", "Data Visualisation",
    ]
    st.caption("Select all keywords visible on the student's CV / resume:")
    selected_kw = st.multiselect("Resume keywords present", resume_kw_options)

    strong_kw = {"SQL", "Python", "Data Integration", "Dashboards", "SAP",
                 "Excel", "Power BI", "Tableau", "ETL", "Machine Learning"}
    matched_strong = [k for k in selected_kw if k in strong_kw]

    if not selected_kw:
        verdict(
            "red",
            "Not Eligible — Resume Does Not Support Application",
            f"Despite <strong>{work_exp} years</strong> of work experience and cognate backlogs, "
            f"no relevant keywords were found on the resume. "
            f"The practical skills evidence required for {course} is not demonstrated.",
        )
    elif len(matched_strong) >= 3:
        verdict(
            "green",
            "Offer Letter — Recommended",
            f"The student has <strong>{backlogs} cognate backlogs</strong>, "
            f"<strong>{work_exp} years</strong> of relevant work experience, "
            f"and a strong CV profile with {len(matched_strong)} key technical skills matched. "
            f"<br><br>An <strong>Offer Letter can be issued</strong>. "
            f"Recommended condition: submission of official transcripts and degree certificate.",
            keywords=kw_list,
        )
    elif len(matched_strong) >= 1 or len(selected_kw) >= 2:
        verdict(
            "amber",
            "Conditional Offer — Senior Review Advised",
            f"The student has <strong>{backlogs} cognate backlogs</strong>, "
            f"<strong>{work_exp} years</strong> of work experience, "
            f"and partial keyword match ({len(selected_kw)} keyword(s) found, "
            f"{len(matched_strong)} strong technical match(es)). "
            f"<br><br>A conditional offer <strong>may be considered</strong> but should be reviewed "
            f"by a senior team member before issue.",
            keywords=kw_list,
        )
    else:
        verdict(
            "red",
            "Not Eligible — Insufficient Technical Evidence",
            f"Work experience is present but the resume does not show sufficient technical "
            f"alignment with {course}. No strong technical keywords matched. "
            f"Entry requirements are not met at this stage.",
        )

